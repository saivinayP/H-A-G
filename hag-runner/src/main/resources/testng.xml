<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">

<!--
    H-A-G Master Test Suite
    ========================
    Four test configurations in one XML:

    1. Smoke    — fast sanity checks (tests/login, tests/smoke)
    2. API      — API-only scenarios (tests/api)
    3. Regression — hand-authored regression tests
    4. BulkAll  — auto-discovers every CSV under tests/ via BulkTestRunner

    Usage:
      mvn test                                # runs All suite (BulkAll)
      mvn test -Dgroups=smoke                 # Smoke group only
      mvn test -Dgroups=api                   # API group only
      mvn test -Dhag.test.root=tests/login    # custom scan root
-->
<suite name="H-A-G Suite" verbose="1" parallel="methods" thread-count="2">

    <!-- ─────────────────── Smoke Suite ─────────────────────────────── -->
    <test name="Smoke">
        <groups>
            <run>
                <include name="smoke"/>
            </run>
        </groups>
        <classes>
            <class name="com.hag.runner.suite.BulkTestRunner"/>
        </classes>
    </test>

    <!-- ─────────────────── API Suite ───────────────────────────────── -->
    <test name="API">
        <groups>
            <run>
                <include name="api"/>
            </run>
        </groups>
        <classes>
            <class name="com.hag.runner.suite.BulkTestRunner"/>
        </classes>
    </test>

    <!-- ─────────────────── Regression Suite ────────────────────────── -->
    <test name="Regression">
        <groups>
            <run>
                <include name="regression"/>
                <include name="e2e"/>
            </run>
        </groups>
        <classes>
            <class name="com.hag.runner.suite.BulkTestRunner"/>
        </classes>
    </test>

    <!-- ─────────────────── Full Bulk Suite (default) ────────────────── -->
    <test name="BulkAll">
        <groups>
            <run>
                <include name="all"/>
            </run>
        </groups>
        <classes>
            <class name="com.hag.runner.suite.BulkTestRunner"/>
        </classes>
    </test>

    <!-- ─────────────────── Listeners ───────────────────────────────── -->
    <listeners>
        <listener class-name="com.hag.runner.listener.HagSuiteListener"/>
    </listeners>

</suite>
