<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">

<!--
  HAG Master Test Suite

  Key parameters:
    - thread-count:    number of parallel browser threads (matches your Grid capacity)
    - data-provider-thread-count: DataProvider parallelism
    - browser:         chrome | firefox | edge
    - headless:        true | false
    - env:             override active-environment from url.config.yml

  Running:
    mvn test -pl hag-runner -am
    mvn test -pl hag-runner -am -Dbrowser=firefox -Dheadless=true
    mvn test -pl hag-runner -am -Dthread.count=4
-->
<suite name="HAG Test Suite"
       verbose="1"
       parallel="methods"
       thread-count="1"
       data-provider-thread-count="4">

    <!-- ══════════════════════════════════════════════════════════
         Suite-level parameters — override via -D system properties
         ══════════════════════════════════════════════════════════ -->
    <parameter name="browser"   value="${browser:chrome}"/>
    <parameter name="headless"  value="${headless:false}"/>

    <!-- ══════════════════════════════════════════════════════════
         Smoke Tests
         ══════════════════════════════════════════════════════════ -->
    <test name="Smoke Tests" preserve-order="true">
        <packages>
            <package name="com.hag.tests.smoke"/>
        </packages>
    </test>

    <!-- ══════════════════════════════════════════════════════════
         Regression Tests
         ══════════════════════════════════════════════════════════ -->
    <test name="Regression Tests">
        <packages>
            <package name="com.hag.tests.regression"/>
        </packages>
    </test>

    <!-- ══════════════════════════════════════════════════════════
         API Tests (no browser needed)
         ══════════════════════════════════════════════════════════ -->
    <test name="API Tests">
        <packages>
            <package name="com.hag.tests.api"/>
        </packages>
    </test>

    <!-- ══════════════════════════════════════════════════════════
         Listeners
         ══════════════════════════════════════════════════════════ -->
    <listeners>
        <listener class-name="com.hag.runner.listener.HagSuiteListener"/>
    </listeners>

</suite>
